{
  "rewrites": [
    {
      "source": "/api/geocode",
      "destination": "https://geocoding.geo.census.gov/geocoder/geographies/address"
    },
    {
      "source": "/api/geocode-coords",
      "destination": "https://geocoding.geo.census.gov/geocoder/geographies/coordinates"
    },
    {
      "source": "/api/nominatim/:path*",
      "destination": "https://nominatim.openstreetmap.org/:path*"
    },
    {
      "source": "/api/hubzone-proxy",
      "destination": "https://maps.certify.sba.gov/api/hubzone"
    }
  ]
}
